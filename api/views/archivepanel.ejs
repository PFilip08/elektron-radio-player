<!-- archivepanel.ejs -->
<%- include('./partials/recoveryStatus.ejs') %>
<h1 id="archiveTitle">Archiwum</h1>
<section style="margin-bottom: 20px;">
    <div id="transferPanel" style="margin-bottom: 20px;">
        <table style="background: darkred;">
            <thead>
                <tr>
                    <th colspan="2">Kopiowanie z archiwum do playlisty 6</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <select id="archiveFolderSelect" style="min-width: 250px; padding: 5px;">
                            <option value="">-- Wybierz podkatalog archiwum --</option>
                        </select>
                    </td>
                    <td>
                        <button onclick="loadArchiveFolders()" style="margin-right: 5px;">Odśwież listę</button>
                        <button onclick="initiateCopyFromArchive()" style="font-weight: bold;">
                            Kopiuj do playlisty 6
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
    <div id="copyPlaylistPanel">
        <table style="background: darkgreen;">
            <thead>
                <tr>
                    <th colspan="3">Przenoszenie playlist do archiwum</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="3">
                        <label for="movePlaylistNotice">Adnotacja (opcjonalnie):</label>
                        <input type="text" id="movePlaylistNotice" placeholder="np. Święto upadku Xeoniarni" style="min-width: 260px;" />
                    </td>
                </tr>
                <tr>
                    <td>
                        <button onclick="movePlaylistToArchive(1)">Klasyczna (1)</button>
                    </td>
                    <td>
                        <button onclick="movePlaylistToArchive(2)">POP (2)</button>
                    </td>
                    <td>
                        <button onclick="movePlaylistToArchive(3)">RAP (3)</button>
                    </td>
                </tr>
                <tr>
                    <td>
                        <button onclick="movePlaylistToArchive(4)">ROCK (4)</button>
                    </td>
                    <td>
                        <button onclick="movePlaylistToArchive(5)">Soundtracki (5)</button>
                    </td>
                    <td>
                        <button onclick="movePlaylistToArchive(6)">Specjalna (6)</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</section>
<section style="display: flex; justify-content: center; flex-wrap: wrap;">
    <div id="anomaliesPanel">
        <table style="background: purple;">
            <thead>
                <tr>
                    <th colspan="2">Wykrywanie anomalii</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="center">
                        <button onclick="filterNoMetadata()">Pokaż piosenki bez metadanych</button>
                    </td>
                    <td class="center">
                        <button onclick="filterCJKCharacters()">Pokaż piosenki z chińskimi/japońskimi znakami</button>
                    </td>
                </tr>
                <tr>
                    <td class="center">
                        <button onclick="filterNoDuration()">Pokaż piosenki bez czasu</button>
                    </td>
                    <td class="center">
                        <button onclick="resetFilters()">Resetuj filtry</button>
                    </td>
                </tr>
            </tbody>
        </table>
        <div id="filterInfo" style="text-align: center; margin-top: 10px; font-size: 1em; color: #ff69b4;"></div>
    </div>
    <div id="locationPanel">
        <table style="background: darkblue;">
            <thead>
            <tr>
                <th colspan="2">Filtrowanie po lokalizacji</th>
            </tr>
            </thead>
            <tbody>
            <tr>
                <td>
                    <button onclick="filterRootFiles()">Pokaż pliki z katalogu głównego</button>
                </td>
                <td>
                    <button onclick="filterSubfolderFiles()">Pokaż pliki z podfolderów</button>
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <button onclick="resetFilters()">Resetuj filtry</button>
                </td>
            </tr>
            </tbody>
        </table>
        <div id="locationInfo" style="margin-top: 10px; font-size: 1em; color: #87ceeb;"></div>
    </div>
</section>
<br/>
<section>
    <div>
        <table style="background: green;">
            <thead>
                <tr>
                    <th colspan="3">Wyszukaj utwór w archiwum</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <span>Tytuł lub wykonawca:</span>
                    </td>
                    <td>
                        <input type="search" id="searchFile" placeholder="np. Taboret, Akcent..." required/>
                        <button onclick="searchFile()">Szukaj</button>
                    </td>
                    <td>
                        <button onclick="resetSearch()">Wyczyść</button>
                    </td>
                </tr>
            </tbody>
        </table>
        <table style="background: darkorange;">
            <thead>
            <tr>
                <th colspan="3">Skopiuj utwór do playlisty</th>
            </tr>
            </thead>
            <tbody>
            <tr>
                <td>
                    <span>Wybierz playlistę:</span>
                </td>
                <td>
                    <select id="playlistFolderSelect" style="min-width: 250px; padding: 5px;">
                        <option value="">-- Wybierz katalog playlisty --</option>
                    </select>
                </td>
            </tr>
            </tbody>
        </table>
        <div id="searchInfo" style="margin-top: 10px; font-size: 1.1em; color: #0f0;"></div>
    </div>
    <div style="margin-bottom: 15px;"><%- include('./partials/res.ejs') %></div>
    <table id="archiveTable" style="background: blue;">
        <thead>
            <tr>
                <th>Lp.</th>
                <th>Tytuł</th>
                <th>Wykonawca</th>
                <th>Czas trwania</th>
                <th>Położenie w archiwum / Nazwa pliku</th>
                <th>Akcja</th>
            </tr>
        </thead>
        <tbody>
        </tbody>
            <tr>
                <td colspan="6">
                    <button onclick="firstPage()"><img src="/images/domek.png" width="14" height="14"></button> <!-- TODO: ma odnosić na pierwszą stronę, a nie do góry-->
                    <button onclick="prevPage()" id="prevBtn" title="Poprzednia">⏪︎</button>
                    <button onclick="fetchArchive()" title="jakieś badziewie">🗘</button>
                    <button onclick="nextPage()" id="nextBtn" title="Następna">⏩︎</button>
                    <button onclick="lastPage()" ><img src="/images/end.png" width="14" height="14"></button>
                </td>
            </tr>
    </table>
    <div style="margin-bottom: 10px;">
        <span>Strona: <span id="pageInfo">1 / 1</span></span>
        <span style="margin-left: 20px;">Łącznie utworów: <span id="totalSongs">0</span></span>
    </div>
</section>
<script src="../js/archive.js" async></script>