<!-- layouts/dev_layout.ejs -->
<!DOCTYPE html>
<html lang="pl">
    <head>
        <meta charset="UTF-8">
        <title><%= title %> - localapi - dev edition</title>
        <link rel="stylesheet" href="/css/style.css">
        <link rel="stylesheet" href="/css/dev.css">
        <script src="/js/dev.js" async></script>
        <script src="/js/lib.js" defer></script>
    </head>
    <body>
        <div class="center">
            <h1><%= welcome %></h1>
            <h2><span class="skew">localapi - dev edition</span></h2>
            <img src="/images/construction.gif" alt="konstrukcja"/>
            <h1 style="color: red;">DO NOT RELEASE THIS TOOL TO CUSTOMER!</h1>
        </div>
        <div class="center main">
            <%- body %>
            <% if (locals.navbar !== false) { %>
                <%- include('../partials/navbar_dev.ejs') -%>
            <% } %>
            <br/>
            <br/>
            <img src="/images/ie_exploder.gif" alt="ie_exploder"/>
            <img src="/images/norton.gif" alt="norton"/>
            <img src="/images/linux_powered.gif" alt="linux_powered"/>
        </div>
    </body>
</html>