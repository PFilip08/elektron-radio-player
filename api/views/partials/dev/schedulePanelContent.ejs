<!-- partials/dev/schedulePanelContent.ejs -->
<div id="schedulePanelContent" style="display: none; margin-top: 20px;">
    <% if (tasks && tasks.length > 0) { %>
        <div>
            <label for="searchInput">Wyszukaj zadanie:</label>
            <input type="text" id="searchInput" onkeyup="filterTasks()" placeholder="Wpisz nazwę zadania...">
            <label for="commandFilter">Wyszukaj po komendzie:</label>
            <input type="text" id="commandFilter" onkeyup="filterTasks()" placeholder="Wpisz komendę...">
            <div style="display: flex; align-items: center; gap: 10px;">
                <label for="dateFilter">Filtruj według daty:</label>
                <input type="date" id="dateFilter" onchange="filterTasks()">
                <button onclick="selectToday()">Dziś</button>
                <button onclick="selectTomorrow()">Jutro</button>
                <button onclick="clearDateFilter()">Wszystkie</button>
            </div>
        </div>
        <table id="tasksTable">
            <thead>
            <tr>
                <th onclick="sortTable(0)">Nazwa zadania</th>
                <th onclick="sortTable(1)">Data</th>
                <th onclick="sortTable(2)">Godzina</th>
                <th>Komenda</th>
                <th>Zmienne</th>
                <th>Akcje</th>
            </tr>
            </thead>
            <tbody>
            <% tasks.forEach(task => { %>
                <tr>
                    <td><%= task.name %></td>
                    <td><%= task.date %></td>
                    <td><%= task.time %></td>
                    <td><%= task.command %></td>
                    <td>
                        <pre><%= JSON.stringify(task.variables, null, 2) %></pre>
                    </td>
                    <td>
                        <button onclick="removeTask('<%= task.name %>')">Usuń</button>
                    </td>
                </tr>
            <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <p>Brak zaplanowanych zadań.</p>
    <% } %>
</div>

<script>
    function selectToday() {
        const dateFilter = document.getElementById('dateFilter');
        dateFilter.value = new Date().toLocaleDateString('sv-SE');
        filterTasks();
    }

    function selectTomorrow() {
        const dateFilter = document.getElementById('dateFilter');
        const tomorrow = new Date();
        tomorrow.setDate(tomorrow.getDate() + 1);
        dateFilter.value = tomorrow.toLocaleDateString('sv-SE');
        filterTasks();
    }

    function clearDateFilter() {
        const dateFilter = document.getElementById('dateFilter');
        dateFilter.value = '';
        filterTasks();
    }
</script>
