<!-- partials/recoveryStatus.ejs -->
<div class="center blink" style="color: red; font-size: xx-large;" id="recoveryModeState"></div>
<script>
    const recoveryModeState = document.getElementById("recoveryModeState");
    const evtSource = new EventSource("/status/query/recoveryMode");
    evtSource.onmessage = (event) => {
        try {
            const data = JSON.parse(event.data);
            recoveryModeState.style.fontSize = "xx-large";
            if (data.status == true) {
                recoveryModeState.style.display = "block";
                if (data.staticPlaylist) {
                    recoveryModeState.innerHTML = "TRYB RECOVERY AKTYWNY!<br> (używanie statycznego zapisu playlist!)"
                } else if (data.previousDataPlaylistUse) {
                    recoveryModeState.innerHTML = "TRYB RECOVERY AKTYWNY!<br> (używanie poprzednio zdobytej playlisty!)";
                } else {
                    recoveryModeState.innerHTML = "TRYB RECOVERY AKTYWNY!<br> (NIEZNANE!)";
                }
            } else {
                recoveryModeState.style.display = "none";
                recoveryModeState.innerHTML = "";
            }
        } catch (e) {
            console.error("Błąd podczas przetwarzania danych statusu trybu recovery:", e);
            console.error("Stacktrace:", e.stack);
        }
    };
    evtSource.onerror = (e) => {
        recoveryModeState.style.display = "block";
        recoveryModeState.style.fontSize = "xxx-large";
        recoveryModeState.innerHTML = "PANEL NIE MA POŁĄCZENIA Z ELP!!!"
        console.error("Błąd podczas ustawiania nasłuchiwania na status trybu recovery:", e);
        console.error("Stacktrace:", e.stack);
    }
</script>